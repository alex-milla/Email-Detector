# ============================================================
#  Email Malware Detector — Configuración
#  Copia este archivo a config/.env y rellena los valores
# ============================================================

# --- Aplicación ---
SECRET_KEY=cambia_esto_por_un_valor_aleatorio
WEB_PORT=5000

# --- Conexión IMAP genérica (Gmail App Password, Outlook...) ---
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# --- Gmail OAuth2 (alternativa al App Password) ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# --- Microsoft 365 / Azure AD ---
# Requiere registro en https://portal.azure.com
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=
MS365_TENANT_ID=
MS365_EMAIL=

# --- VirusTotal API ---
VIRUSTOTAL_API_KEY=

# --- Modelos ML ---
# GPU: true activa GPU en el modelo Anti-Clanker si hay CUDA disponible
USE_GPU=false
# Modelos desactivados (separados por coma, ej: "model_3,model_7")
DISABLED_MODELS=

# --- Anti-Clanker (Modelo 10) ---
# URL pública para auto-actualización de reglas (dejar vacío para desactivar)
CLANKER_RULES_URL=
CLANKER_AUTO_UPDATE=false
# Peso del modelo Clanker en el ensemble (0.0 - 1.0)
CLANKER_MODEL_WEIGHT=0.1

# --- HTTPS (solo si se usa certificado propio) ---
# SSL_CERT=/ruta/a/fullchain.pem
# SSL_KEY=/ruta/a/privkey.pem
